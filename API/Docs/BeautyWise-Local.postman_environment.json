{
  "id": "bw-env-local",
  "name": "BeautyWise - Local",
  "_postman_variable_scope": "environment",
  "values": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7001",
      "type": "default",
      "enabled": true,
      "description": "dotnet run sonrası terminalde yazan port neyse onu yaz"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Login sonrası otomatik dolar. Manuel girme."
    },
    {
      "key": "invite_token",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Personel davet token'ı. invite-token endpoint'inden otomatik dolar."
    },
    {
      "key": "merchant_oid",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "PayTR sipariş numarası. Purchase endpoint'inden otomatik dolar."
    },
    {
      "key": "tenant_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Kayıt sonrası otomatik dolar."
    },
    {
      "key": "owner_email",
      "value": "owner@guzeleller.com",
      "type": "default",
      "enabled": true,
      "description": "Test için Owner e-posta adresi"
    },
    {
      "key": "owner_password",
      "value": "Test@1234",
      "type": "secret",
      "enabled": true,
      "description": "Test için Owner şifresi"
    },
    {
      "key": "staff_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Login sonrası JWT'den otomatik parse edilir. Personel randevu/program endpointlerinde kullanılır."
    },
    {
      "key": "treatment_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Hizmet oluşturma (POST /api/treatment) sonrası otomatik dolar."
    },
    {
      "key": "customer_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Müşteri oluşturma (POST /api/customer) sonrası otomatik dolar."
    },
    {
      "key": "appointment_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Randevu oluşturma (POST /api/appointment) sonrası otomatik dolar."
    },
    {
      "key": "unavailability_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Kapalı aralık oluşturma (POST /api/staffschedule/unavailability) sonrası otomatik dolar."
    },
    {
      "key": "payment_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Ödeme kaydetme (POST /api/appointmentpayment) sonrası otomatik dolar."
    },
    {
      "key": "expense_category_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Gider kategorisi oluşturma (POST /api/expense/category) sonrası otomatik dolar."
    },
    {
      "key": "expense_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Gider kaydı oluşturma (POST /api/expense) sonrası otomatik dolar."
    }
  ]
