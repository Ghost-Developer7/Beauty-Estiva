<UserControl x:Class="BeautyEstiva.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#0f0a1e" />
        <SolidColorBrush x:Key="CardBorder" Color="#1a1030" />
        <SolidColorBrush x:Key="TextMuted" Color="#9a88c2" />
        <SolidColorBrush x:Key="TextDim" Color="#5a4d7a" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="28,24">
            <!-- Welcome -->
            <TextBlock FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,4">
                <Run Text="{DynamicResource Welcome}" /><Run Text=", " /><Run Text="{Binding Path=DataContext.UserName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue=''}" />
            </TextBlock>
            <TextBlock Text="{DynamicResource Dashboard}" Foreground="{StaticResource TextDim}"
                       FontSize="13" Margin="0,0,0,28" />

            <!-- Loading -->
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Value="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                         HorizontalAlignment="Center" Margin="0,0,0,16" />

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#ef4444"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"
                       Margin="0,0,0,16" />

            <!-- KPI Cards Row -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">
                <!-- Today Appointments -->
                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="16" Padding="20,18" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource TodayAppointments}" Foreground="{StaticResource TextDim}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding TodayAppointmentsCount}" FontSize="32" FontWeight="Bold" Foreground="White" />
                            <Border Background="#1a1040" CornerRadius="8" Padding="8,4" Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="#ec4899">
                                    <Run Text="{Binding UpcomingAppointments}" /><Run Text=" " />
                                    <Run Text="{DynamicResource UpcomingAppointments}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Monthly Revenue -->
                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="16" Padding="20,18" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MonthlyRevenue}" Foreground="{StaticResource TextDim}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding MonthlyRevenue, StringFormat={}{0:N0} TL}" FontSize="28" FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6c5ce7" Offset="0" />
                                    <GradientStop Color="#ec4899" Offset="1" />
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Total Customers -->
                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="16" Padding="20,18" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource TotalCustomers}" Foreground="{StaticResource TextDim}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding TotalCustomers}" FontSize="32" FontWeight="Bold" Foreground="White" />
                    </StackPanel>
                </Border>

                <!-- Weekly Revenue -->
                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="16" Padding="20,18" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource WeeklyRevenue}" Foreground="{StaticResource TextDim}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding WeeklyRevenue, StringFormat={}{0:N0} TL}" FontSize="28" FontWeight="Bold" Foreground="#10b981" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts + Schedule Row -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Monthly Trend Chart -->
                <Border Grid.Column="0" Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="16" Padding="20,18" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MonthlyTrend}" Foreground="{StaticResource TextDim}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,16" />
                        <lvc:CartesianChart Series="{Binding MonthlyTrendSeries}"
                                            XAxes="{Binding MonthlyTrendXAxes}"
                                            Height="280" />
                    </StackPanel>
                </Border>

                <!-- Today Schedule -->
                <Border Grid.Column="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="16" Padding="20,18" Margin="8,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource TodaySchedule}"
                                   Foreground="{StaticResource TextDim}" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,16" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TodaySchedule}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#1a1030" BorderThickness="0,0,0,1" Padding="0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="55" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Time}" Foreground="#ec4899"
                                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Top" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding CustomerName}" Foreground="White"
                                                               FontSize="13" FontWeight="Medium" />
                                                    <TextBlock Text="{Binding TreatmentName}" Foreground="{StaticResource TextDim}"
                                                               FontSize="11" Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding StaffName}" Foreground="#5a4d7a"
                                                               FontSize="10" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
