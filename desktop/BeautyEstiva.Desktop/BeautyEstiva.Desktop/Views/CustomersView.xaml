<UserControl x:Class="BeautyEstiva.Desktop.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#0f0a1e" />
        <SolidColorBrush x:Key="CardBorder" Color="#1a1030" />
        <SolidColorBrush x:Key="TextDim" Color="#5a4d7a" />
        <SolidColorBrush x:Key="RowHover" Color="#130e22" />
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{DynamicResource Customers}" FontSize="24" FontWeight="Bold"
                       Foreground="White" DockPanel.Dock="Left" VerticalAlignment="Center" />
            <Button Command="{Binding OpenAddDialogCommand}" DockPanel.Dock="Right"
                    HorizontalAlignment="Right" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="12" Padding="18,10" Cursor="Hand">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#6c5ce7" Offset="0" />
                                                <GradientStop Color="#8b5cf6" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Foreground="White" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{DynamicResource Add}" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </DockPanel>

        <!-- Search -->
        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="1" CornerRadius="12" Padding="14,10" Margin="0,0,0,16">
            <DockPanel>
                <materialDesign:PackIcon Kind="Magnify" Foreground="#5a4d7a" Width="20" Height="20"
                                        DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="White" FontSize="14" Background="Transparent" BorderThickness="0"
                         CaretBrush="White" VerticalAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- Loading -->
        <ProgressBar Grid.Row="2" Style="{StaticResource MaterialDesignCircularProgressBar}"
                     IsIndeterminate="True" Value="0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" />

        <!-- Data Table -->
        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="1" CornerRadius="16" Padding="0">
            <DataGrid ItemsSource="{Binding Customers}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" SelectionMode="Single" HeadersVisibility="Column"
                      Background="Transparent" Foreground="White" BorderThickness="0"
                      RowBackground="#0f0a1e" AlternatingRowBackground="#110c20"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1a1030"
                      FontSize="13">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0a0815" />
                        <Setter Property="Foreground" Value="#5a4d7a" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="16,12" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="#1a1030" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="16,10" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1a1030" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="AD SOYAD" Binding="{Binding FullName}" Width="*" />
                    <DataGridTextColumn Header="TELEFON" Binding="{Binding Phone}" Width="140" />
                    <DataGridTextColumn Header="E-POSTA" Binding="{Binding Email}" Width="180" />
                    <DataGridTextColumn Header="ZIYARET" Binding="{Binding TotalVisits}" Width="80" />
                    <DataGridTextColumn Header="HARCAMA" Binding="{Binding TotalSpent, StringFormat={}{0:N0}}" Width="110" />
                    <DataGridTemplateColumn Header="ISLEMLER" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.OpenEditDialogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand"
                                            Style="{StaticResource MaterialDesignIconButton}" Foreground="#8a7cb0" Width="32" Height="32">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" />
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand"
                                            Style="{StaticResource MaterialDesignIconButton}" Foreground="#ef4444" Width="32" Height="32">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Pagination -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="{DynamicResource Previous}" Command="{Binding PreviousPageCommand}"
                    Foreground="#8a7cb0" Background="Transparent" BorderBrush="#1a1030"
                    BorderThickness="1" Padding="16,8" Margin="0,0,8,0" Cursor="Hand" />
            <TextBlock VerticalAlignment="Center" Margin="8,0" Foreground="#5a4d7a" FontSize="13">
                <Run Text="{Binding CurrentPage}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
            </TextBlock>
            <Button Content="{DynamicResource Next}" Command="{Binding NextPageCommand}"
                    Foreground="#8a7cb0" Background="Transparent" BorderBrush="#1a1030"
                    BorderThickness="1" Padding="16,8" Margin="8,0,0,0" Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>
