<Window x:Class="BeautyEstiva.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:BeautyEstiva.Desktop.ViewModels"
        xmlns:views="clr-namespace:BeautyEstiva.Desktop.Views"
        Title="Beauty Estiva" Height="800" Width="1320"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- Colors matching web theme -->
        <SolidColorBrush x:Key="SidebarBg" Color="#0d0518" />
        <SolidColorBrush x:Key="PanelBg" Color="#090414" />
        <SolidColorBrush x:Key="TopbarBg" Color="#0f0820" />
        <SolidColorBrush x:Key="TopbarBorder" Color="#1a1030" />
        <SolidColorBrush x:Key="NavItemHover" Color="#1a1030" />
        <SolidColorBrush x:Key="NavItemActive" Color="#1f1540" />
        <SolidColorBrush x:Key="TextWhite" Color="White" />
        <SolidColorBrush x:Key="TextMuted" Color="#9a88c2" />
        <SolidColorBrush x:Key="TextDim" Color="#5a4d7a" />
        <SolidColorBrush x:Key="SidebarBorder" Color="#1a1030" />
        <SolidColorBrush x:Key="AccentPurple" Color="#6c5ce7" />
        <SolidColorBrush x:Key="AccentPink" Color="#fd79a8" />
        <SolidColorBrush x:Key="OnlineGreen" Color="#10b981" />

        <!-- Nav button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8a7cb0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1a1030" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav button style -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#1f1540" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- View-ViewModel DataTemplate mappings -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomersViewModel}">
            <views:CustomersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AppointmentsViewModel}">
            <views:AppointmentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TreatmentsViewModel}">
            <views:TreatmentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StaffViewModel}">
            <views:StaffView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource PanelBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar (web-matching dark purple gradient) -->
        <Border Grid.Column="0" Width="256"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#140622" Offset="0" />
                    <GradientStop Color="#040309" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel>
                <!-- Logo Header -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,0">
                    <StackPanel Orientation="Horizontal">
                        <!-- Logo circle -->
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6c5ce7" Offset="0" />
                                    <GradientStop Color="#fd79a8" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="E" Foreground="White" FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ESTIVA" Foreground="#9a88c2" FontSize="10"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Beauty OS" Foreground="White" FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Version footer -->
                <Border DockPanel.Dock="Bottom" BorderBrush="#1a1030" BorderThickness="0,1,0,0"
                        Padding="20,16">
                    <TextBlock Text="version 1.0 / Desktop" Foreground="#5a4d7a" FontSize="11" />
                </Border>

                <!-- Nav Items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,20,8,0">
                    <StackPanel>
                        <Button Style="{StaticResource NavButton}" Tag="Dashboard" Click="NavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#0a0815" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Foreground="#8a7cb0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                </Border>
                                <TextBlock Text="{DynamicResource Dashboard}" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}" Tag="Appointments" Click="NavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#0a0815" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="ClockOutline" Foreground="#8a7cb0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                </Border>
                                <TextBlock Text="{DynamicResource Appointments}" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}" Tag="Customers" Click="NavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#0a0815" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="AccountGroup" Foreground="#8a7cb0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                </Border>
                                <TextBlock Text="{DynamicResource Customers}" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}" Tag="Treatments" Click="NavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#0a0815" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="ContentCut" Foreground="#8a7cb0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                </Border>
                                <TextBlock Text="{DynamicResource Treatments}" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}" Tag="Staff" Click="NavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#0a0815" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="BadgeAccount" Foreground="#8a7cb0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                </Border>
                                <TextBlock Text="{DynamicResource Staff}" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButton}" Tag="Settings" Click="NavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#0a0815" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="Cog" Foreground="#8a7cb0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" Width="18" Height="18" />
                                </Border>
                                <TextBlock Text="{DynamicResource Settings}" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <DockPanel Grid.Column="1">
            <!-- Topbar (web-matching) -->
            <Border DockPanel.Dock="Top" Background="{StaticResource TopbarBg}"
                    BorderBrush="{StaticResource TopbarBorder}" BorderThickness="0,0,0,1"
                    Padding="20,12"
                    Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DockPanel>
                    <!-- Right: User info + logout -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- User avatar + info -->
                        <Border CornerRadius="16" BorderBrush="#1a1030" BorderThickness="1"
                                Background="#0f0820" Padding="6,4,16,4">
                            <StackPanel Orientation="Horizontal">
                                <!-- Avatar -->
                                <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#ffd1dc" Offset="0" />
                                            <GradientStop Color="#f3a4ff" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="{Binding UserInitials}" Foreground="#2e174e"
                                               FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UserName}" Foreground="White"
                                               FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding UserRoles}" Foreground="#5a4d7a"
                                               FontSize="10" FontWeight="Medium" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Logout -->
                        <Button Command="{Binding LogoutCommand}" Margin="12,0,0,0" Cursor="Hand"
                                ToolTip="{DynamicResource Logout}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Width="36" Height="36" CornerRadius="10"
                                                        Background="#0f0820" Cursor="Hand">
                                                    <materialDesign:PackIcon Kind="Logout" Foreground="#8a7cb0"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Width="18" Height="18" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1a1030" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Left: empty space or search could go here -->
                    <TextBlock />
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <ContentControl Content="{Binding CurrentView}" />
        </DockPanel>
    </Grid>
</Window>
