generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model EFMigrationsHistory {
  MigrationId    String @id(map: "PK___EFMigrationsHistory") @db.NVarChar(150)
  ProductVersion String @db.NVarChar(32)

  @@map("__EFMigrationsHistory")
}

model AppointmentPayments {
  Id                     Int                      @id(map: "PK_AppointmentPayments") @default(autoincrement())
  TenantId               Int
  AppointmentId          Int
  Amount                 Decimal                  @db.Decimal(18, 2)
  CurrencyId             Int
  ExchangeRateToTry      Decimal                  @db.Decimal(18, 6)
  AmountInTry            Decimal                  @db.Decimal(18, 2)
  PaymentMethod          Int
  PaidAt                 DateTime
  Notes                  String?                  @db.NVarChar(Max)
  CUser                  Int?
  UUser                  Int?
  CDate                  DateTime?
  UDate                  DateTime?
  IsActive               Boolean?
  Appointments           Appointments             @relation(fields: [AppointmentId], references: [Id], onUpdate: NoAction, map: "FK_AppointmentPayments_Appointments_AppointmentId")
  Currencies             Currencies               @relation(fields: [CurrencyId], references: [Id], onUpdate: NoAction, map: "FK_AppointmentPayments_Currencies_CurrencyId")
  Tenants                Tenants                  @relation(fields: [TenantId], references: [Id], onUpdate: NoAction, map: "FK_AppointmentPayments_Tenants_TenantId")
  StaffCommissionRecords StaffCommissionRecords[]

  @@index([AppointmentId], map: "IX_AppointmentPayments_AppointmentId")
  @@index([CurrencyId], map: "IX_AppointmentPayments_CurrencyId")
  @@index([TenantId], map: "IX_AppointmentPayments_TenantId")
}

model Appointments {
  Id                     Int                   @id(map: "PK_Appointments") @default(autoincrement())
  TenantId               Int
  CustomerId             Int
  StaffId                Int
  TreatmentId            Int
  StartTime              DateTime
  EndTime                DateTime
  Status                 Int
  Notes                  String?               @db.NVarChar(Max)
  IsRecurring            Boolean
  RecurrenceIntervalDays Int?
  TotalSessions          Int?
  SessionNumber          Int
  ParentAppointmentId    Int?
  CUser                  Int?
  UUser                  Int?
  CDate                  DateTime?
  UDate                  DateTime?
  IsActive               Boolean?
  AppointmentPayments    AppointmentPayments[]
  Appointments           Appointments?         @relation("AppointmentsToAppointments", fields: [ParentAppointmentId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Appointments_Appointments_ParentAppointmentId")
  other_Appointments     Appointments[]        @relation("AppointmentsToAppointments")
  Customers              Customers             @relation(fields: [CustomerId], references: [Id], onUpdate: NoAction, map: "FK_Appointments_Customers_CustomerId")
  Tenants                Tenants               @relation(fields: [TenantId], references: [Id], onUpdate: NoAction, map: "FK_Appointments_Tenants_TenantId")
  Treatments             Treatments            @relation(fields: [TreatmentId], references: [Id], onUpdate: NoAction, map: "FK_Appointments_Treatments_TreatmentId")
  Users                  Users                 @relation(fields: [StaffId], references: [Id], onUpdate: NoAction, map: "FK_Appointments_Users_StaffId")

  @@index([CustomerId], map: "IX_Appointments_CustomerId")
  @@index([ParentAppointmentId], map: "IX_Appointments_ParentAppointmentId")
  @@index([StaffId], map: "IX_Appointments_StaffId")
  @@index([TenantId], map: "IX_Appointments_TenantId")
  @@index([TreatmentId], map: "IX_Appointments_TreatmentId")
}

model Branches {
  Id               Int       @id(map: "PK_Branches") @default(autoincrement())
  TenantId         Int
  Name             String    @db.NVarChar(200)
  Address          String?   @db.NVarChar(500)
  Phone            String?   @db.NVarChar(30)
  Email            String?   @db.NVarChar(150)
  WorkingHoursJson String?   @db.NVarChar(2000)
  IsMainBranch     Boolean
  CUser            Int?
  UUser            Int?
  CDate            DateTime?
  UDate            DateTime?
  IsActive         Boolean?
  Tenants          Tenants   @relation(fields: [TenantId], references: [Id], onUpdate: NoAction, map: "FK_Branches_Tenants_TenantId")
  Users            Users[]

  @@index([TenantId], map: "IX_Branches_TenantId")
}

model Coupons {
  Id                  Int                   @id(map: "PK_Coupons") @default(autoincrement())
  Code                String                @db.NVarChar(50)
  Description         String?               @db.NVarChar(200)
  IsPercentage        Boolean
  DiscountAmount      Decimal               @db.Decimal(18, 2)
  StartDate           DateTime
  EndDate             DateTime
  MaxUsageCount       Int?
  CurrentUsageCount   Int
  IsGlobal            Boolean
  SpecificTenantId    Int?
  CUser               Int?
  UUser               Int?
  CDate               DateTime?
  UDate               DateTime?
  IsActive            Boolean?
  Tenants             Tenants?              @relation(fields: [SpecificTenantId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Coupons_Tenants_SpecificTenantId")
  CouponUsages        CouponUsages[]
  TenantSubscriptions TenantSubscriptions[]

  @@index([SpecificTenantId], map: "IX_Coupons_SpecificTenantId")
}

model CouponUsages {
  Id                  Int                 @id(map: "PK_CouponUsages") @default(autoincrement())
  CouponId            Int
  TenantId            Int
  SubscriptionId      Int
  OriginalPrice       Decimal             @db.Decimal(18, 2)
  DiscountAmount      Decimal             @db.Decimal(18, 2)
  FinalPrice          Decimal             @db.Decimal(18, 2)
  UsedDate            DateTime
  CUser               Int?
  UUser               Int?
  CDate               DateTime?
  UDate               DateTime?
  IsActive            Boolean?
  Coupons             Coupons             @relation(fields: [CouponId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_CouponUsages_Coupons_CouponId")
  Tenants             Tenants             @relation(fields: [TenantId], references: [Id], onUpdate: NoAction, map: "FK_CouponUsages_Tenants_TenantId")
  TenantSubscriptions TenantSubscriptions @relation(fields: [SubscriptionId], references: [Id], onUpdate: NoAction, map: "FK_CouponUsages_TenantSubscriptions_SubscriptionId")

  @@index([CouponId], map: "IX_CouponUsages_CouponId")
  @@index([SubscriptionId], map: "IX_CouponUsages_SubscriptionId")
  @@index([TenantId], map: "IX_CouponUsages_TenantId")
}

model Currencies {
  Id                  Int                   @id(map: "PK_Currencies") @default(autoincrement())
  Code                String                @db.NVarChar(10)
  Symbol              String                @db.NVarChar(5)
  Name                String                @db.NVarChar(100)
  IsDefault           Boolean
  IsActive            Boolean
  DisplayOrder        Int
  ExchangeRateToTry   Decimal?              @db.Decimal(18, 6)
  RateLastUpdated     DateTime?
  TcmbCurrencyCode    String?               @db.NVarChar(10)
  AppointmentPayments AppointmentPayments[]
  Expenses            Expenses[]
  ProductSales        ProductSales[]
}

model CustomerDebtPayments {
  Id             Int           @id(map: "PK_CustomerDebtPayments") @default(autoincrement())
  TenantId       Int
  CustomerDebtId Int
  Amount         Decimal       @db.Decimal(18, 2)
  PaymentMethod  String        @db.NVarChar(50)
  Notes          String?
  PaymentDate    DateTime
  CUser          Int?
  UUser          Int?
  CDate          DateTime?
  UDate          DateTime?
  IsActive       Boolean?
  CustomerDebts  CustomerDebts @relation(fields: [CustomerDebtId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_CustomerDebtPayments_CustomerDebts_CustomerDebtId")

  @@index([CustomerDebtId], map: "IX_CustomerDebtPayments_CustomerDebtId")
  @@index([TenantId, PaymentDate], map: "IX_CustomerDebtPayments_TenantId_PaymentDate")
}

model CustomerDebts {
  Id                   Int                    @id(map: "PK_CustomerDebts") @default(autoincrement())
  TenantId             Int
  CustomerId           Int?
  PersonName           String?                @db.NVarChar(200)
  Type                 String                 @db.NVarChar(20)
  Amount               Decimal                @db.Decimal(18, 2)
  PaidAmount           Decimal                @db.Decimal(18, 2)
  Currency             String?                @db.NVarChar(10)
  Description          String?                @db.NVarChar(500)
  Notes                String?
  DueDate              DateTime?
  Status               String                 @db.NVarChar(20)
  RelatedAppointmentId Int?
  RelatedPackageSaleId Int?
  Source               String?                @db.NVarChar(50)
  CUser                Int?
  UUser                Int?
  CDate                DateTime?
  UDate                DateTime?
  IsActive             Boolean?
  CustomerDebtPayments CustomerDebtPayments[]
  Customers            Customers?             @relation(fields: [CustomerId], references: [Id], onUpdate: NoAction, map: "FK_CustomerDebts_Customers_CustomerId")
  Tenants              Tenants                @relation(fields: [TenantId], references: [Id], onUpdate: NoAction, map: "FK_CustomerDebts_Tenants_TenantId")

  @@index([CustomerId], map: "IX_CustomerDebts_CustomerId")
  @@index([TenantId, Type, Status], map: "IX_CustomerDebts_TenantId_Type_Status")
}

model Customers {
  Id                    Int                     @id(map: "PK_Customers") @default(autoincrement())
  TenantId              Int
  Name                  String                  @db.NVarChar(Max)
  Surname               String                  @db.NVarChar(Max)
  Phone                 String                  @db.NVarChar(Max)
  Email                 String?                 @db.NVarChar(Max)
  BirthDate             DateTime?
  Notes                 String?                 @db.NVarChar(Max)
  CUser                 Int?
  UUser                 Int?
  CDate                 DateTime?
  UDate                 DateTime?
  IsActive              Boolean?
  Allergies             String?                 @db.NVarChar(Max)
  CustomerSince         DateTime                @default(dbgenerated("0001-01-01T00:00:00.0000000"), map: "DF__Customers__Custo__318258D2")
  LastVisitDate         DateTime?
  LoyaltyPoints         Int                     @default(0, map: "DF__Customers__Loyal__32767D0B")
  Preferences           String?                 @db.NVarChar(Max)
  PreferredStaffId      Int?
  ReferralSource        String?                 @db.NVarChar(Max)
  Tags                  String?                 @db.NVarChar(Max)
  TotalSpent            Decimal                 @default(0.0, map: "DF__Customers__Total__336AA144") @db.Decimal(18, 2)
  TotalVisits           Int                     @default(0, map: "DF__Customers__Total__345EC57D")
  Appointments          Appointments[]
  CustomerDebts         CustomerDebts[]
  Tenants               Tenants                 @relation(fields: [TenantId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Customers_Tenants_TenantId")
  Users                 Users?                  @relation(fields: [PreferredStaffId], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Customers_Users_PreferredStaffId")
  PackageSales_Packages PackageSales_Packages[]
  ProductSales          ProductSales[]

  @@index([PreferredStaffId], map: "IX_Customers_PreferredStaffId")
  @@index([TenantId], map: "IX_Customers_TenantId")
}

model ExpenseCategories {
  Id       Int        @id(map: "PK_ExpenseCategories") @default(autoincrement())
  TenantId Int
  Name     String     @db.NVarChar(100)
  Color    String?    @db.NVarChar(Max)
  CUser    Int?
  UUser    Int?
  CDate    DateTime?
  UDate    DateTime?
  IsActive Boolean?
  Tenants  Tenants    @relation(fields: [TenantId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_ExpenseCategories_Tenants_TenantId")
  Expenses Expenses[]

  @@index([TenantId], map: "IX_ExpenseCategories_TenantId")
}

model Expenses {
  Id                Int                @id(map: "PK_Expenses") @default(autoincrement())
  TenantId          Int
  ExpenseCategoryId Int?
  Amount            Decimal            @db.Decimal(18, 2)
  CurrencyId        Int
  ExchangeRateToTry Decimal            @db.Decimal(18, 6)
  AmountInTry       Decimal            @db.Decimal(18, 2)
  Description       String             @db.NVarChar(500)
  ExpenseDate       DateTime
  ReceiptNumber     String?            @db.NVarChar(Max)
  Notes             String?            @db.NVarChar(Max)
  CUser             Int?
  UUser             Int?
  CDate             DateTime?
  UDate             DateTime?
  IsActive          Boolean?
  Currencies        Currencies         @relation(fields: [CurrencyId], references: [Id], onUpdate: NoAction, map: "FK_Expenses_Currencies_CurrencyId")
  ExpenseCategories ExpenseCategories? @relation(fields: [ExpenseCategoryId], references: [Id], onUpdate: NoAction, map: "FK_Expenses_ExpenseCategories_ExpenseCategoryId")
  Tenants           Tenants            @relation(fields: [TenantId], references: [Id], onUpdate: NoAction, map: "FK_Expenses_Tenants_TenantId")

  @@index([CurrencyId], map: "IX_Expenses_CurrencyId")
  @@index([ExpenseCategoryId], map: "IX_Expenses_ExpenseCategoryId")
  @@index([TenantId], map: "IX_Expenses_TenantId")
}

model InAppNotifications {
  Id               Int       @id(map: "PK_InAppNotifications") @default(autoincrement())
  TenantId         Int
  UserId           Int?
  Title            String    @db.NVarChar(200)
  Message          String
  Type             String    @db.NVarChar(20)
  EntityType       String?   @db.NVarChar(50)
  EntityId         Int?
  IsRead           Boolean
  ReadAt           DateTime?
  ActionUrl        String?   @db.NVarChar(500)
